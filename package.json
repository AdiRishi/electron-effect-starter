{
  "name": "@app/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:web": "node scripts/dev-runner.ts dev:web",
    "dev:desktop": "node scripts/dev-runner.ts dev:desktop",
    "build": "pnpm -r --if-present --filter './apps/*' --filter './packages/*' build",
    "build:desktop": "pnpm --filter @app/web build && pnpm --filter @app/server build && pnpm --filter @app/desktop build",
    "start:desktop": "pnpm --filter @app/desktop start",
    "typecheck": "pnpm -r --if-present --workspace-concurrency=2 typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm typecheck",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "dist:desktop": "node scripts/build-desktop-artifact.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
